[node name="Help3" type="Label" parent="Options" unique_id=1060831912]
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -856.5
offset_top = -629.5
offset_right = 884.0
offset_bottom = 584.0
grow_horizontal = 2
grow_vertical = 2
theme_override_font_sizes/font_size = 48
theme_override_styles/normal = SubResource("StyleBoxFlat_fga63")
text = "卡牌介绍：
前进牌（GO）：
前进x格：移动到距离棋子x格的位置（障碍物除外）
功能牌（TRICK）：
（只有UNIVERSAL）无中生有：摸两张牌
重铸：使用后此牌消失并摸一张牌
（UNIVERSAL）化险为夷：消除指定位置的障碍物
（UNIVERSAL）乾坤重置：重新生成地图
点染一格：将指定格子颜色改为同此牌颜色（不要对着自己脚下格子使用哦）
障碍重重：指定格子生成障碍物
原地待命：跳过下位玩家的所有阶段
束手待毙：跳过下位的出牌阶段
韬光养晦：跳过自己的弃牌阶段
釜底抽薪：跳过下位的摸牌阶段
交换人生：顺时针交换玩家手牌"

