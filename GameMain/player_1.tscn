theme_override_styles/normal = SubResource("StyleBoxFlat_fga63")
text = "游戏基本规则：

玩家采取回合制游玩，每回合只能打出对应棋子所在格子颜色（LAND，GREEN，PINK，RIVER）的手牌进行地图改变，或者棋子移动。任一玩家的棋子移动到地图终点视为游戏结束。手牌分为前进牌（GO）和功能牌（TRICK），每回合功能牌无限制使用，前进牌一旦生效即进入弃牌阶段结束回合。部分卡牌拥有UNIVERSAL（万能）特性，不受格子颜色限制。玩家初始手牌为5张（可更改），每回合摸牌2张，出牌结束手牌数大于五触发弃牌至手牌等于5张。"
autowrap_mode = 2

